// Prisma Schema for Hair Solutions Customer Portal

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  SUPPORT
  ADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PRODUCTION
  QUALITY_CHECK
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ProductionStage {
  AWAITING_CONFIRMATION
  MATERIALS_PREPARATION
  BASE_CONSTRUCTION
  HAIR_VENTILATION
  STYLING
  QUALITY_INSPECTION
  PACKAGING
  COMPLETED
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CUSTOMER
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ReminderStatus {
  SCHEDULED
  SENT
  CONFIRMED
  POSTPONED
  CANCELLED
}

enum NotionResourceType {
  HELP_ARTICLE
  CARE_GUIDE
  PERSONAL_NOTE
  GENERAL_KNOWLEDGE
}

// ============ User & Authentication ============

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  emailVerified     DateTime?
  name              String?
  password          String
  role              UserRole  @default(CUSTOMER)
  stripeCustomerId  String?   @unique

  // 2FA
  twoFactorEnabled  Boolean   @default(false)
  twoFactorSecret   String?

  // Profile
  phone             String?
  shippingAddress   Json?     // { street, city, state, zip, country }

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  accounts          Account[]
  sessions          Session[]
  hairProfile       HairProfile?
  orders            Order[]
  invoices          Invoice[]
  supportTickets    SupportTicket[]
  customizationTemplates CustomizationTemplate[]
  customerPlan      CustomerPlan?
  notionResources   CustomerNotionResource[]
  auditLogs         AuditLog[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  // Device/session tracking
  userAgent    String?
  ipAddress    String?
  deviceName   String?  // e.g., "iPhone", "Chrome on MacBook"
  lastActive   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ============ Hair Profile & Customization ============

model HairProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique

  // Measurements
  headCircumference     Float?   // in cm or inches
  frontToNape           Float?
  earToEar              Float?
  templeToTemple        Float?
  measurements          Json?    // Additional detailed measurements

  // Preferences
  preferredStyle        String?
  density               String?  // Light, Medium, Heavy
  hairColor             String?
  baseType              String?  // Lace, Skin, Mono, etc.
  attachmentMethod      String?  // Tape, Glue, Clips, etc.

  // Lifestyle
  activityLevel         String?  // Low, Moderate, High
  sweatingLevel         String?  // Low, Moderate, High
  workEnvironment       String?
  sportsActivities      String[]

  // Photos
  photoFront            String?  // URL to uploaded photo
  photoSide             String?
  photoBack             String?
  photoTop              String?
  additionalPhotos      String[]

  // Notes
  notes                 String?  @db.Text

  // Onboarding
  onboardingCompleted   Boolean  @default(false)
  onboardingStep        Int      @default(0)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("hair_profiles")
}

model CustomizationTemplate {
  id                String   @id @default(cuid())
  userId            String
  name              String   // e.g., "Standard System", "Summer System"

  // Configuration
  baseType          String
  hairColor         String
  density           String
  hairLength        String
  style             String
  attachmentMethod  String
  additionalOptions Json?    // Any other customization options

  isDefault         Boolean  @default(false) // Used for quick reorder

  notes             String?  @db.Text

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders            Order[]

  @@map("customization_templates")
}

// ============ Orders & Production ============

model Order {
  id                        String            @id @default(cuid())
  orderNumber               String            @unique
  userId                    String

  // Shopify Integration
  shopifyOrderId            String?           @unique
  shopifyOrderNumber        String?

  // Order Details
  productName               String
  customizationTemplateId   String?
  configurationSnapshot     Json              // Full config at time of order

  // Status & Production
  status                    OrderStatus       @default(PENDING)
  productionStage           ProductionStage   @default(AWAITING_CONFIRMATION)

  // Pricing
  subtotal                  Float
  tax                       Float             @default(0)
  shipping                  Float             @default(0)
  total                     Float
  currency                  String            @default("USD")

  // Dates
  estimatedProductionStart  DateTime?
  estimatedCompletion       DateTime?
  actualCompletionDate      DateTime?
  shippedAt                 DateTime?
  deliveredAt               DateTime?

  // Notes
  customerNotes             String?           @db.Text
  internalNotes             String?           @db.Text

  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  // Relations
  user                      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  customizationTemplate     CustomizationTemplate? @relation(fields: [customizationTemplateId], references: [id], onDelete: SetNull)
  statusHistory             OrderStatusHistory[]
  invoices                  Invoice[]
  productionSchedule        OrderProductionSchedule?

  @@index([userId])
  @@map("orders")
}

model OrderStatusHistory {
  id          String      @id @default(cuid())
  orderId     String
  status      OrderStatus
  stage       ProductionStage?
  notes       String?     @db.Text
  createdBy   String?     // User ID or "system"
  createdAt   DateTime    @default(now())

  order       Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("order_status_history")
}

model OrderProductionSchedule {
  id                              String          @id @default(cuid())
  orderId                         String          @unique
  userId                          String

  // Scheduling
  scheduledProductionDate         DateTime
  scheduledCompletionDate         DateTime?

  // Customization Confirmation
  customizationConfirmed          Boolean         @default(false)
  customizationConfirmedAt        DateTime?
  confirmedConfigurationSnapshot  Json?

  // Reminders
  reminderStatus                  ReminderStatus  @default(SCHEDULED)
  reminderSentAt                  DateTime?
  reminderCount                   Int             @default(0)

  // Postponement
  originalScheduledDate           DateTime?
  postponedCount                  Int             @default(0)
  postponementReason              String?

  createdAt                       DateTime        @default(now())
  updatedAt                       DateTime        @updatedAt

  order                           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("order_production_schedules")
}

// ============ Invoices ============

model Invoice {
  id                String          @id @default(cuid())
  invoiceNumber     String          @unique
  userId            String
  orderId           String?

  // Stripe Integration
  stripeInvoiceId   String?         @unique

  // Invoice Details
  amount            Float
  tax               Float           @default(0)
  total             Float
  currency          String          @default("USD")

  status            InvoiceStatus   @default(PENDING)

  // Dates
  issueDate         DateTime        @default(now())
  dueDate           DateTime?
  paidAt            DateTime?

  // Files
  pdfUrl            String?

  description       String?         @db.Text

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  order             Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("invoices")
}

// ============ Subscriptions & Plans ============

model SubscriptionPlan {
  id                    String   @id @default(cuid())
  name                  String   @unique
  description           String?  @db.Text

  // Stripe Integration
  stripePriceId         String?  @unique
  stripeProductId       String?

  // Pricing
  price                 Float
  currency              String   @default("USD")
  interval              String   // "month", "year"
  intervalCount         Int      @default(1)

  // Features
  features              Json     // Array of feature strings
  systemsPerYear        Int      // Number of hair systems included per year

  // Scheduling
  defaultProductionFrequency Int? // Days between automatic productions

  isActive              Boolean  @default(true)
  displayOrder          Int      @default(0)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  customerPlans         CustomerPlan[]

  @@map("subscription_plans")
}

model CustomerPlan {
  id                        String            @id @default(cuid())
  userId                    String            @unique
  planId                    String

  // Stripe Integration
  stripeSubscriptionId      String?           @unique

  // Status
  status                    String            @default("active") // active, cancelled, past_due

  // Dates
  currentPeriodStart        DateTime
  currentPeriodEnd          DateTime
  cancelAt                  DateTime?
  cancelledAt               DateTime?

  // Next Production
  nextScheduledProduction   DateTime?

  createdAt                 DateTime          @default(now())
  updatedAt                 DateTime          @updatedAt

  user                      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                      SubscriptionPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("customer_plans")
}

// ============ Products (Mini Shop) ============

model Product {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique
  description       String?  @db.Text
  shortDescription  String?

  // Shopify Integration
  shopifyProductId  String?  @unique
  shopifyVariantId  String?

  // Pricing
  price             Float
  compareAtPrice    Float?   // Original price for "on sale" display
  currency          String   @default("USD")

  // Product Details
  category          String?  // "shampoo", "tape", "adhesive", etc.
  images            String[] // Array of image URLs
  primaryImage      String?

  // Inventory
  inStock           Boolean  @default(true)
  stockQuantity     Int?

  // Display
  featured          Boolean  @default(false)
  displayOrder      Int      @default(0)
  isActive          Boolean  @default(true)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("products")
}

// ============ Support Tickets ============

model SupportTicket {
  id          String          @id @default(cuid())
  ticketNumber String         @unique
  userId      String

  subject     String
  status      TicketStatus    @default(OPEN)
  priority    TicketPriority  @default(MEDIUM)

  // Assignment
  assignedTo  String?         // User ID of support/admin

  // Metadata
  category    String?         // "order", "billing", "technical", etc.
  tags        String[]

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  closedAt    DateTime?

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    SupportMessage[]

  @@index([userId])
  @@map("support_tickets")
}

model SupportMessage {
  id          String        @id @default(cuid())
  ticketId    String

  senderId    String        // User ID
  senderType  UserRole      // CUSTOMER, SUPPORT, ADMIN

  content     String        @db.Text
  attachments String[]      // URLs to uploaded files

  isInternal  Boolean       @default(false) // Internal notes not visible to customer

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("support_messages")
}

// ============ Notion Integration ============

model CustomerNotionResource {
  id            String              @id @default(cuid())
  userId        String

  notionPageId  String
  type          NotionResourceType

  title         String
  slug          String?
  category      String?

  // Cache
  content       String?             @db.Text // Cached markdown content
  lastSynced    DateTime?

  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  user          User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, notionPageId])
  @@map("customer_notion_resources")
}

model HelpArticle {
  id            String   @id @default(cuid())

  // Notion Integration
  notionPageId  String?  @unique

  title         String
  slug          String   @unique
  content       String   @db.Text
  excerpt       String?

  category      String
  tags          String[]

  // Display
  featured      Boolean  @default(false)
  displayOrder  Int      @default(0)
  isPublished   Boolean  @default(true)

  // SEO
  metaTitle     String?
  metaDescription String?

  // Sync
  lastSynced    DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("help_articles")
}

// ============ Affiliated Locations ============

model AffiliatedLocation {
  id              String   @id @default(cuid())

  name            String
  slug            String   @unique

  // Address
  country         String
  state           String?
  city            String
  address         String?
  postalCode      String?

  // Contact
  phone           String?
  email           String?
  website         String?

  // Services
  servicesOffered String[]
  specialties     String[]

  // Geo
  latitude        Float?
  longitude       Float?

  // Details
  description     String?  @db.Text
  logoUrl         String?
  images          String[]

  // Status
  isActive        Boolean  @default(true)
  isFeatured      Boolean  @default(false)

  // Display
  displayOrder    Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("affiliated_locations")
}

// ============ Audit Logs ============

model AuditLog {
  id          String   @id @default(cuid())

  // Actor
  userId      String?
  actor       String   // "user:{id}", "system", "webhook", etc.

  // Action
  action      String   // "created", "updated", "deleted", "accessed"
  entityType  String   // "Order", "User", "Invoice", etc.
  entityId    String?

  // Details
  metadata    Json?    // Additional context
  ipAddress   String?
  userAgent   String?

  createdAt   DateTime @default(now())

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============ Feature Flags (for future) ============

model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  enabled     Boolean  @default(false)

  // Rollout
  rolloutPercentage Int @default(0) // 0-100

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("feature_flags")
}
