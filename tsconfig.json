{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["esnext"],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["tailwind.config.ts"],
  "exclude": [
    "node_modules",
    ".next",
    "app",
    "components",
    "lib",
    "prisma",
    "middleware.ts",
    "next-env.d.ts"
  ]
}
