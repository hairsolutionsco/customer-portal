{
  "name": "hair-solutions-customer-portal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"console.log('CMS default workspace: use npm run portal:build or npm run portal:verify for the HubSpot theme. Use npm run legacy:dev only when intentionally starting the archived Next.js app.')\"",
    "build": "npm run portal:build",
    "start": "node -e \"console.log('CMS default workspace: there is no local CMS runtime server here. Use npm run portal:ship to upload theme changes, or npm run legacy:start for the archived Next.js app.')\"",
    "lint": "npm run portal:build",
    "legacy:dev": "NEXT_TYPESCRIPT_TSCONFIG=tsconfig.legacy.json next dev",
    "legacy:build": "NEXT_TYPESCRIPT_TSCONFIG=tsconfig.legacy.json next build",
    "legacy:start": "NEXT_TYPESCRIPT_TSCONFIG=tsconfig.legacy.json next start",
    "legacy:lint": "NEXT_TYPESCRIPT_TSCONFIG=tsconfig.legacy.json next lint",
    "legacy:typecheck": "npx tsc --noEmit -p tsconfig.legacy.json",
    "legacy:prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "postinstall": "node -e \"console.log('postinstall: CMS default workspace; run npm run legacy:prisma:generate only when working on the archived Next.js app.')\"",
    "portal:issues": "bash scripts/sync-github-exports.sh",
    "portal:handoff-check": "PORTAL_REPO_ROOT=\"$PWD\" python3 scripts/portal_handoff_reality_check.py",
    "portal:build": "bash scripts/portal_build.sh",
    "portal:verify": "npm run portal:build",
    "portal:release": "bash scripts/portal_release.sh",
    "portal:ship": "bash scripts/portal_task_complete.sh",
    "portal:fetch": "bash ops/scripts/fetch_hubspot_theme.sh",
    "portal:hubspot-props": "python3 scripts/hubspot_create_portal_contact_properties.py",
    "portal:hubdb-sync": "python3 scripts/hubspot_sync_hubdb.py",
    "portal:op": "bash scripts/op_env.sh",
    "portal:cursor-op": "bash scripts/cursor_with_op_env.sh",
    "portal:automation": "bash scripts/portal_automation_full.sh",
    "portal:automation:continue": "bash scripts/portal_automation_full.sh --continue-on-error",
    "portal:hubspot-cli-version": "node -e \"console.log('@hubspot/cli', require('./node_modules/@hubspot/cli/package.json').version)\"",
    "portal:cms-upload-draft": "cd theme && hs cms upload . customer-portal -m draft",
    "portal:cms-upload-publish": "cd theme && hs cms upload . customer-portal -m publish"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.18",
    "@heroicons/react": "^2.1.1",
    "@hookform/resolvers": "^3.3.4",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@notionhq/client": "^2.2.14",
    "@prisma/client": "^5.9.1",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "next": "^14.2.35",
    "next-auth": "^4.24.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "stripe": "^14.14.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@hubspot/cli": "^8.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.33",
    "prisma": "^5.9.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
