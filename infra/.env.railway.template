# Railway Environment Variables Template
# Copy these variables to Railway Dashboard or use the CLI to set them
# DO NOT commit this file with actual values!

# ============================================
# REQUIRED - Auto-configured by Railway
# ============================================

# DATABASE_URL is automatically provided by Railway PostgreSQL
# DATABASE_URL=postgresql://...  (DO NOT SET MANUALLY)

# ============================================
# REQUIRED - Set after first deployment
# ============================================

# NextAuth Configuration
NEXTAUTH_SECRET=                     # Generate with: openssl rand -base64 32
NEXTAUTH_URL=                        # Your Railway app URL, e.g., https://your-app.railway.app
NEXT_PUBLIC_APP_URL=                 # Same as NEXTAUTH_URL
NEXT_PUBLIC_SITE_NAME=Hair Solutions Customer Portal

# ============================================
# REQUIRED - Stripe Payment Integration
# ============================================

STRIPE_SECRET_KEY=                   # Get from Stripe Dashboard → Developers → API keys
STRIPE_PUBLISHABLE_KEY=              # Get from Stripe Dashboard → Developers → API keys
STRIPE_WEBHOOK_SECRET=               # Get from Stripe Dashboard → Developers → Webhooks

# ============================================
# OPTIONAL - Shopify Integration
# ============================================

SHOPIFY_STORE_DOMAIN=                # e.g., your-store.myshopify.com
SHOPIFY_ADMIN_API_TOKEN=             # Get from Shopify Admin → Apps → Create private app
SHOPIFY_WEBHOOK_SECRET=              # Set when creating Shopify webhooks

# ============================================
# OPTIONAL - Notion Integration
# ============================================

NOTION_API_KEY=                      # Get from Notion → Settings → Integrations
NOTION_HELP_DATABASE_ID=             # Copy from Notion database URL

# ============================================
# OPTIONAL - Email/SMTP Configuration
# ============================================

SMTP_HOST=smtp.gmail.com             # Your SMTP server
SMTP_PORT=587                        # SMTP port (usually 587 for TLS)
SMTP_USER=                           # Your email address
SMTP_PASSWORD=                       # Your app-specific password (for Gmail)
EMAIL_FROM=Hair Solutions <noreply@hairsolutions.co>

# ============================================
# HOW TO SET THESE VARIABLES IN RAILWAY
# ============================================

# Option 1: Using Railway CLI
# ----------------------------
# railway variables set VARIABLE_NAME="value"
#
# Example:
# railway variables set NEXTAUTH_SECRET="$(openssl rand -base64 32)"
# railway variables set STRIPE_SECRET_KEY="sk_live_..."

# Option 2: Using Railway Dashboard
# ----------------------------------
# 1. Go to https://railway.app/dashboard
# 2. Select your project
# 3. Click on your service
# 4. Go to "Variables" tab
# 5. Click "New Variable" for each variable
# 6. Or use "RAW Editor" to paste all at once

# Option 3: Bulk Set via CLI
# ---------------------------
# Copy the commands below and fill in your values:

# railway variables set NEXTAUTH_SECRET="$(openssl rand -base64 32)"
# railway variables set NEXTAUTH_URL="https://your-app.railway.app"
# railway variables set NEXT_PUBLIC_APP_URL="https://your-app.railway.app"
# railway variables set NEXT_PUBLIC_SITE_NAME="Hair Solutions Customer Portal"
# railway variables set STRIPE_SECRET_KEY="sk_live_..."
# railway variables set STRIPE_PUBLISHABLE_KEY="pk_live_..."
# railway variables set STRIPE_WEBHOOK_SECRET="whsec_..."
# railway variables set SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
# railway variables set SHOPIFY_ADMIN_API_TOKEN="shpat_..."
# railway variables set SHOPIFY_WEBHOOK_SECRET="your-webhook-secret"
# railway variables set NOTION_API_KEY="secret_..."
# railway variables set NOTION_HELP_DATABASE_ID="..."
# railway variables set SMTP_HOST="smtp.gmail.com"
# railway variables set SMTP_PORT="587"
# railway variables set SMTP_USER="your-email@gmail.com"
# railway variables set SMTP_PASSWORD="your-app-password"
# railway variables set EMAIL_FROM="Hair Solutions <noreply@hairsolutions.co>"
