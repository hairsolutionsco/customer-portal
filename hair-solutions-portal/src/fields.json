[
  {
    "label": "Portal brand",
    "name": "portal",
    "type": "group",
    "children": [
      {
        "label": "Brand color",
        "name": "brand_color",
        "type": "color",
        "visibility": { "hidden_subfields": { "opacity": true } },
        "default": { "color": "#1a1a2e" }
      },
      {
        "label": "Accent color",
        "name": "accent_color",
        "type": "color",
        "visibility": { "hidden_subfields": { "opacity": true } },
        "default": { "color": "#e94560" }
      },
      {
        "label": "Success color",
        "name": "success_color",
        "type": "color",
        "visibility": { "hidden_subfields": { "opacity": true } },
        "default": { "color": "#22c55e" }
      },
      {
        "label": "Warning color",
        "name": "warning_color",
        "type": "color",
        "visibility": { "hidden_subfields": { "opacity": true } },
        "default": { "color": "#f59e0b" }
      },
      {
        "label": "Error color",
        "name": "error_color",
        "type": "color",
        "visibility": { "hidden_subfields": { "opacity": true } },
        "default": { "color": "#ef4444" }
      },
      {
        "label": "Logo",
        "name": "logo",
        "type": "image",
        "resizable": true,
        "responsive": true,
        "show_loading": false,
        "default": { "size_type": "auto", "src": "", "alt": "Hair Solutions" }
      }
    ]
  },
  {
    "label": "Portal layout",
    "name": "portal_layout",
    "type": "group",
    "children": [
      {
        "label": "Sidebar width",
        "name": "sidebar_width",
        "type": "number",
        "display": "text",
        "min": 220,
        "max": 360,
        "suffix": "px",
        "default": 280
      }
    ]
  }
]
