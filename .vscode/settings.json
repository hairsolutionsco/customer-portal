{
  "git.openRepositoryInParentFolders": "never",
  "files.autoSave": "afterDelay",
  "files.autoSaveDelay": 800,
  "search.exclude": {
    "**/node_modules": true,
    "**/.next": true,
    "**/dist": true,
    "**/coverage": true,
    "**/.DS_Store": true
  },
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/*/**": true,
    "**/.next/**": true
  },
  "workbench.editor.enablePreview": false,
  "workbench.startupEditor": "none"
}
