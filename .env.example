# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hair_solutions_portal?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Stripe
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Shopify
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_ADMIN_API_TOKEN="shpat_..."
SHOPIFY_WEBHOOK_SECRET="your-webhook-secret"

# Notion
NOTION_API_KEY="secret_..."
NOTION_HELP_DATABASE_ID="..." # Database ID for general help articles

# Email (for notifications and password reset)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="Hair Solutions <noreply@hairsolutions.co>"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="Hair Solutions Customer Portal"

# File Upload (optional - for future use)
# AWS_S3_BUCKET="your-bucket"
# AWS_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="..."
# AWS_SECRET_ACCESS_KEY="..."

# HubSpot — Portal 2.0 theme / API (optional local copy of secrets)
# - `.env` is gitignored — copy this file: `cp .env.example .env` and paste your keys only on your machine.
# - HubSpot CLI (`hs`) normally stores auth in `~/.hscli/config.yml` and/or `hair-solutions-portal/hubspot.config.yml` (gitignored). These vars are for your reference and for scripts that read `process.env`.
# - `npm run portal:hubspot-props` creates portal contact properties (#11) using HUBSPOT_PRIVATE_APP__CRM_SCHEMA__ACCESS_TOKEN (Private App: crm.schemas.contacts.write).
# - `npm run portal:hubdb-sync` creates/publishes HubDB tables from `hair-solutions-portal/hubdb/*.json` using HUBSPOT_PRIVATE_APP__HUBDB__ACCESS_TOKEN (must include **hubdb** scope).
# - If these keys were ever pasted into chat or a screenshot, rotate them in HubSpot and generate new ones.
HUBSPOT_PRIVATE_APP__CRM_SCHEMA__ACCESS_TOKEN=""
HUBSPOT_PRIVATE_APP__HUBDB__ACCESS_TOKEN=""
HUBSPOT_PRIVATE_APP__OPS__ACCESS_TOKEN=""
# Optional: portal account ID (from `hs accounts list`) — not a secret but useful for docs/scripts
# HUBSPOT_PORTAL_ID=""
